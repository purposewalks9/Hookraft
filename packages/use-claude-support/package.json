{
  "name": "use-claude-support",
  "version": "0.1.0",
  "description": "Add an AI-powered support chat to any React or Next.js app in minutes. Powered by Claude.",
  "author": "virus",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "pub:release": "npm publish --access public"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "react",
    "hooks",
    "claude",
    "ai",
    "support",
    "chat",
    "widget",
    "anthropic",
    "customer-support",
    "nextjs",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/purposewalks9/Hookraft"
  },
  "homepage": "https://hookraft.site"
}